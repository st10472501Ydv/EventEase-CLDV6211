@model IEnumerable<EventEase.Models.Event>
<h1>Events</h1>
<p><a asp-action="Create">Create New</a></p>
<table class="table">
    <thead><tr><th>Name</th><th>Start Date</th><th>End Date</th><th></th></tr></thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.StartDate.ToShortDateString()</td>
                <td>@item.EndDate.ToShortDateString()</td>
                <td><a asp-action="Details" asp-route-id="@item.EventId">Details</a> | <a asp-action="Edit" asp-route-id="@item.EventId">Edit</a> | <a asp-action="Delete" asp-route-id="@item.EventId">Delete</a></td>
            </tr>
        }
    </tbody>
</table>