@model IEnumerable<EventEase.Models.Booking>
<h1>Bookings</h1>
<p><a asp-action="Create">Create New</a></p>
<table class="table">
    <thead><tr><th>Venue</th><th>Event</th><th>Booking Date</th><th>Status</th><th></th></tr></thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Venue?.Name</td>
                <td>@item.Event?.Name</td>
                <td>@item.BookingDate.ToShortDateString()</td>
                <td>@item.Status</td>
                <td><a asp-action="Details" asp-route-id="@item.BookingId">Details</a> | <a asp-action="Delete" asp-route-id="@item.BookingId">Delete</a></td>
            </tr>
        }
    </tbody>
</table>