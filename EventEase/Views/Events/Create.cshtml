@model EventEase.Models.Event
<h1>Create Event</h1>
<form asp-action="Create">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="form-group">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="StartDate"></label>
        <input asp-for="StartDate" type="datetime-local" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
    </div>
    <div class="form-group">
        <label asp-for="EndDate"></label>
        <input asp-for="EndDate" type="datetime-local" class="form-control" value="@DateTime.Now.AddDays(1).ToString("yyyy-MM-ddTHH:mm")" />
    </div>
    <div class="form-group">
        <label asp-for="OrganizerName"></label>
        <input asp-for="OrganizerName" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="OrganizerEmail"></label>
        <input asp-for="OrganizerEmail" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="EventTypeId" class="control-label"></label>
        <select asp-for="EventTypeId" class="form-control" asp-items="ViewBag.EventTypeId">
            <option value="">-- Select Type --</option>
        </select>
        <span asp-validation-for="EventTypeId" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Create</button>
</form>
<div><a asp-action="Index">Back to List</a></div>