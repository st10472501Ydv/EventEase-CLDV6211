@model IEnumerable<EventEase.Models.Booking>

@{
    ViewData["Title"] = "Bookings";
}

<h2>Bookings</h2>

<form asp-action="Index" method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Search by venue, event, status, or booking ID..." />
        <div class="input-group-append">
            <button type="submit" class="btn btn-primary">Search</button>
            <a asp-action="Index" class="btn btn-secondary">Clear</a>
        </div>
    </div>
</form>

<p>
    <a asp-action="Create" class="btn btn-success">Create New Booking</a>
</p>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<table class="table table-striped table-hover">
    <thead class="thead-dark">
        <tr>
            <th>Venue</th>
            <th>Event</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Booking Date</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Venue.Name)</td>
                <td>@Html.DisplayFor(modelItem => item.Event.Name)</td>
                <td>@item.Event.StartDate.ToShortDateString()</td>
                <td>@item.Event.EndDate.ToShortDateString()</td>
                <td>@item.BookingDate.ToShortDateString()</td>
                <td>
                    @if (item.Status == "Confirmed")
                    {
                        <span class="badge badge-success">Confirmed</span>
                    }
                    else if (item.Status == "Cancelled")
                    {
                        <span class="badge badge-danger">Cancelled</span>
                    }
                    else
                    {
                        <span class="badge badge-secondary">@item.Status</span>
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.BookingId" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.BookingId" class="btn btn-sm btn-danger">Cancel</a>
                </td>
            </tr>
        }
    </tbody>
</table>