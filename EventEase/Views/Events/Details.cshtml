@model EventEase.Models.Event
<h1>Details</h1>
<div>
    <h4>@Model.Name</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Start</dt>
        <dd class="col-sm-10">@Model.StartDate.ToString("g")</dd>
        <dt class="col-sm-2">End</dt>
        <dd class="col-sm-10">@Model.EndDate.ToString("g")</dd>
        <dt class="col-sm-2">Organizer</dt>
        <dd class="col-sm-10">@Model.OrganizerName</dd>
        <dt class="col-sm-2">Organizer Email</dt>
        <dd class="col-sm-10">@Model.OrganizerEmail</dd>
        <dt class="col-sm-2">Description</dt>
        <dd class="col-sm-10">@Model.Description</dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model.EventId">Edit</a> |
    <a asp-action="Index">Back</a>
</div>