@model IEnumerable<EventEase.Models.Booking>

@{
    ViewData["Title"] = "Bookings";
    var eventTypes = (SelectList)ViewData["EventTypeId"];
}

<h2>Bookings</h2>

<form asp-action="Index" method="get" class="mb-3">
    <div class="row">
        <div class="col-md-3">
            <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Search venue, event, status, ID..." />
        </div>
        <div class="col-md-2">
            <select name="eventTypeId" class="form-control" asp-items="@eventTypes">
                <option value="">All Event Types</option>
            </select>
        </div>
        <div class="col-md-2">
            <input type="date" name="fromDate" value="@ViewData["FromDate"]" class="form-control" placeholder="From" />
        </div>
        <div class="col-md-2">
            <input type="date" name="toDate" value="@ViewData["ToDate"]" class="form-control" placeholder="To" />
        </div>
        <div class="col-md-1">
            <div class="form-check">
                <input type="checkbox" name="availableOnly" value="true" class="form-check-input" @(ViewData["AvailableOnly"] as bool? == true ? "checked" : "") />
                <label class="form-check-label">Available Only</label>
            </div>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary">Filter</button>
            <a asp-action="Index" class="btn btn-secondary">Clear</a>
        </div>
    </div>
</form>

<p><a asp-action="Create" class="btn btn-success">Create New Booking</a></p>

@if (TempData["Error"] != null) { <div class="alert alert-danger">@TempData["Error"]</div> }
@if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }

<table class="table table-striped table-hover">
    <thead class="thead-dark">
        <tr>
            <th>Venue</th>
            <th>Event</th>
            <th>Event Type</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Booking Date</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>@Html.DisplayFor(modelItem => item.Venue.Name)</td>
            <td>@Html.DisplayFor(modelItem => item.Event.Name)</td>
            <td>@(item.Event.EventType?.Name ?? "N/A")</td>
            <td>@item.Event.StartDate.ToShortDateString()</td>
            <td>@item.Event.EndDate.ToShortDateString()</td>
            <td>@item.BookingDate.ToShortDateString()</td>
            <td>
                @if (item.Status == "Confirmed") { <span class="badge badge-success">Confirmed</span> }
                else if (item.Status == "Cancelled") { <span class="badge badge-danger">Cancelled</span> }
                else { <span class="badge badge-secondary">@item.Status</span> }
            </td>
            <td>
                <a asp-action="Details" asp-route-id="@item.BookingId" class="btn btn-sm btn-info">Details</a>
                <a asp-action="Delete" asp-route-id="@item.BookingId" class="btn btn-sm btn-danger">Cancel</a>
            </td>
        </tr>
}
    </tbody>
</table>
